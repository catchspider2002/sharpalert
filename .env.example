# Reference list of required secrets (documentation only).
# On Cloudflare: local dev -> `.dev.vars`; production -> `wrangler secret put NAME`.
TXLINE_API_KEY=your_txline_key
DEEPINFRA_API_KEY=your_deepinfra_key
# Optional - only if posting high-confidence alerts to a channel:
TELEGRAM_BOT_TOKEN=your_botfather_token
TELEGRAM_CHANNEL_ID=@SharpAlertWC
