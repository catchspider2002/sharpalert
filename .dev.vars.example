# Copy this file to `.dev.vars` (gitignored) and fill in real values for `wrangler dev`.
# For PRODUCTION, do NOT use a file - set each with:  wrangler secret put NAME
TXLINE_API_KEY="your_txline_key"
ANTHROPIC_API_KEY="your_anthropic_key"
# Optional - only if posting high-confidence alerts to a channel:
TELEGRAM_BOT_TOKEN="your_botfather_token"
TELEGRAM_CHANNEL_ID="@SharpAlertWC"
